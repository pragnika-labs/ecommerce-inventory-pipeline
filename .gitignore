# Python cache files — auto-generated, not needed on GitHub
__pycache__/
*.pyc
*.pyo

# Jupyter notebook checkpoints — auto-saved drafts, not needed
.ipynb_checkpoints/

# Environment variables file — if you ever store passwords here
.env

# VS Code editor settings — personal to your machine
.vscode/

# Operating system files — hidden files Windows/Mac create automatically
.DS_Store
Thumbs.db

# Temporary daily CSV — deleted after ETL loads it to database
data/*.csv